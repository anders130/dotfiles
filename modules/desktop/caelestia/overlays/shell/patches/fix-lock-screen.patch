+        if (lock.locked || root.lockTriggered)
+            return;
+        root.lockTriggered = true;
+        lock.locked = true;
+    }
 
     WlSessionLock {
         id: lock
 
         signal unlock
 
+        onLockedChanged: if (!locked)
+            root.lockTriggered = false
+
         LockSurface {
             lock: lock
